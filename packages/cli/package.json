{
  "name": "@repo/cli",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "cfc": "dist/cfc-cli"
  },
  "scripts": {
    "start": "bun run index.ts",
    "compile": "bun build --compile --minify --bytecode ./index.ts --outfile dist/cfc-cli",
    "compile:linux-x64": "bun build --compile --minify --bytecode --target=bun-linux-x64 ./index.ts --outfile dist/cfc-cli-linux-x64",
    "compile:linux-arm64": "bun build --compile --minify --bytecode --target=bun-linux-arm64 ./index.ts --outfile dist/cfc-cli-linux-arm64",
    "compile:darwin-x64": "bun build --compile --minify --bytecode --target=bun-darwin-x64 ./index.ts --outfile dist/cfc-cli-darwin-x64",
    "compile:darwin-arm64": "bun build --compile --minify --bytecode --target=bun-darwin-arm64 ./index.ts --outfile dist/cfc-cli-darwin-arm64",
    "compile:windows-x64": "bun build --compile --minify --bytecode --target=bun-windows-x64 ./index.ts --outfile dist/cfc-cli-windows-x64",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64 && bun run compile:windows-x64",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "bun test"
  },
  "dependencies": {
    "@inquirer/core": "^11.1.9",
    "@inquirer/prompts": "^8.3.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
